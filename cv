<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>باسم — مشرف معرض</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#12141c;
    --panel:#1a1d29;
    --panel-2:#20drop;
    --purple:#7c4dff;
    --purple-soft:#7c4dff26;
    --gold:#e8b84b;
    --paper:#f5f3ec;
    --slate:#8d96ae;
    --line:rgba(255,255,255,0.09);
    --radius:14px;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--ink);
    color:var(--paper);
    font-family:'IBM Plex Sans Arabic','Inter',sans-serif;
    line-height:1.65;
    overflow-x:hidden;
  }
  html[dir="ltr"] body{ font-family:'Inter','IBM Plex Sans Arabic',sans-serif; }
  .mono{ font-family:'IBM Plex Mono', monospace; letter-spacing:0.02em; }

  a{ color:inherit; text-decoration:none; }
  .wrap{ max-width:1080px; margin:0 auto; padding:0 28px; }

  /* signal bars motif */
  .bars{ display:inline-flex; align-items:flex-end; gap:3px; height:14px; }
  .bars span{ width:4px; background:var(--purple); border-radius:1px; display:block; }
  .bars span:nth-child(1){ height:35%; }
  .bars span:nth-child(2){ height:60%; }
  .bars span:nth-child(3){ height:80%; }
  .bars span:nth-child(4){ height:100%; background:var(--gold); }

  /* header */
  header{
    position:sticky; top:0; z-index:50;
    background:rgba(18,20,28,0.82);
    backdrop-filter:blur(10px);
    border-bottom:1px solid var(--line);
  }
  header .wrap{ display:flex; align-items:center; justify-content:space-between; height:76px; }
  .logo{ display:flex; align-items:center; gap:12px; }
  .logo-mark{ width:40px; height:40px; }
  .logo-name{ font-weight:600; font-size:15px; letter-spacing:0.02em; }
  .logo-name small{ display:block; font-size:11px; color:var(--slate); font-weight:400; margin-top:2px;}

  nav{ display:flex; align-items:center; gap:28px; }
  nav a.navlink{ font-size:14px; color:var(--slate); transition:color .2s; }
  nav a.navlink:hover{ color:var(--paper); }
  .lang-btn{
    border:1px solid var(--line); background:transparent; color:var(--paper);
    padding:8px 16px; border-radius:100px; font-size:13px; cursor:pointer;
    font-family:inherit; transition:border-color .2s, background .2s;
  }
  .lang-btn:hover{ border-color:var(--purple); background:var(--purple-soft); }
  .lang-btn:focus-visible, a:focus-visible, button:focus-visible{ outline:2px solid var(--gold); outline-offset:3px; }

  @media (max-width:720px){ nav .navlink{ display:none; } }

  /* hero */
  .hero{ padding:88px 0 64px; position:relative; }
  .hero-grid{ display:grid; grid-template-columns:1.2fr 0.8fr; gap:56px; align-items:center; }
  @media (max-width:860px){ .hero-grid{ grid-template-columns:1fr; } }

  .eyebrow{
    display:inline-flex; align-items:center; gap:8px;
    font-size:12px; color:var(--gold); text-transform:uppercase; letter-spacing:0.12em;
    margin-bottom:22px; font-weight:600;
  }
  html[dir="rtl"] .eyebrow{ letter-spacing:0.02em; text-transform:none; }

  h1{ font-size:52px; font-weight:700; line-height:1.15; margin-bottom:18px; }
  @media (max-width:600px){ h1{ font-size:36px; } }
  .role{ font-size:19px; color:var(--purple); font-weight:600; margin-bottom:18px; }
  .pitch{ font-size:16px; color:var(--slate); max-width:520px; margin-bottom:34px; }
  .cta-row{ display:flex; gap:14px; flex-wrap:wrap; }
  .btn{
    padding:13px 26px; border-radius:100px; font-size:14px; font-weight:600;
    display:inline-flex; align-items:center; gap:8px; transition:transform .2s, opacity .2s;
  }
  .btn-primary{ background:var(--purple); color:#fff; }
  .btn-ghost{ border:1px solid var(--line); color:var(--paper); }
  .btn:hover{ transform:translateY(-2px); }
  @media (prefers-reduced-motion:reduce){ .btn:hover{ transform:none; } }

  /* gauge */
  .gauge-wrap{ display:flex; flex-direction:column; align-items:center; justify-content:center; }
  .gauge{ position:relative; width:260px; height:260px; }
  .gauge svg{ width:100%; height:100%; transform:rotate(-90deg); }
  .gauge-track{ fill:none; stroke:var(--line); stroke-width:14; }
  .gauge-fill{ fill:none; stroke:var(--purple); stroke-width:14; stroke-linecap:round;
    stroke-dasharray:691; stroke-dashoffset:691; transition:stroke-dashoffset 1.6s cubic-bezier(.2,.8,.2,1); }
  .gauge-center{ position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; }
  .gauge-num{ font-size:42px; font-weight:700; color:var(--paper); }
  .gauge-label{ font-size:12px; color:var(--slate); margin-top:6px; text-align:center; max-width:150px; }

  /* sections */
  section{ padding:72px 0; border-top:1px solid var(--line); }
  .section-head{ margin-bottom:40px; }
  .section-eyebrow{ font-size:12px; color:var(--gold); font-weight:600; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:10px; }
  html[dir="rtl"] .section-eyebrow{ text-transform:none; letter-spacing:0; }
  h2{ font-size:30px; font-weight:700; }

  /* about */
  .about-grid{ display:grid; grid-template-columns:1fr 1fr; gap:48px; }
  @media (max-width:800px){ .about-grid{ grid-template-columns:1fr; } }
  .about-text p{ color:var(--slate); margin-bottom:16px; font-size:15.5px; }
  .fact-list{ display:flex; flex-direction:column; gap:0; }
  .fact{ display:flex; justify-content:space-between; padding:16px 0; border-bottom:1px solid var(--line); }
  .fact:first-child{ padding-top:0; }
  .fact-k{ color:var(--slate); font-size:14px; }
  .fact-v{ font-weight:600; font-size:14px; }

  /* stat cards */
  .stat-grid{ display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:44px; }
  @media (max-width:800px){ .stat-grid{ grid-template-columns:repeat(2,1fr); } }
  .stat-card{
    background:var(--panel); border:1px solid var(--line); border-radius:var(--radius);
    padding:24px 20px; transition:border-color .25s, transform .25s;
  }
  .stat-card:hover{ border-color:var(--purple); transform:translateY(-3px); }
  @media (prefers-reduced-motion:reduce){ .stat-card:hover{ transform:none; } }
  .stat-num{ font-size:30px; font-weight:700; color:var(--gold); }
  .stat-label{ font-size:13px; color:var(--slate); margin-top:8px; }

  .project-card{
    background:var(--panel); border:1px solid var(--line); border-radius:var(--radius);
    padding:30px; margin-bottom:20px;
  }
  .project-top{ display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; flex-wrap:wrap; gap:10px;}
  .project-title{ font-size:19px; font-weight:700; }
  .tag{ font-size:11px; color:var(--purple); border:1px solid var(--purple); border-radius:100px; padding:4px 12px; }
  .project-desc{ color:var(--slate); font-size:15px; margin-bottom:16px; }
  .project-points{ display:flex; flex-direction:column; gap:10px; }
  .point{ display:flex; align-items:flex-start; gap:10px; font-size:14px; }
  .point .bars{ margin-top:4px; flex-shrink:0; }

  /* career path */
  .path{ display:flex; flex-direction:column; gap:0; }
  .path-item{ display:flex; gap:20px; padding:22px 0; border-bottom:1px solid var(--line); align-items:flex-start; }
  .path-item:last-child{ border-bottom:none; }
  .path-num{ font-family:'IBM Plex Mono',monospace; color:var(--slate); font-size:13px; padding-top:4px; min-width:26px; }
  .path-item.current .path-num{ color:var(--gold); }
  .path-title{ font-weight:600; font-size:16px; margin-bottom:4px; }
  .path-item.current .path-title{ color:var(--gold); }
  .path-desc{ color:var(--slate); font-size:14px; }

  /* skills */
  .skills-grid{ display:flex; flex-wrap:wrap; gap:10px; }
  .skill-pill{
    border:1px solid var(--line); border-radius:100px; padding:10px 18px; font-size:13.5px;
    background:var(--panel);
  }

  /* footer/contact */
  footer{ padding:64px 0 40px; border-top:1px solid var(--line); }
  .contact-grid{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:24px; }
  .contact-cta h2{ margin-bottom:12px; }
  .contact-cta p{ color:var(--slate); max-width:420px; }
  .contact-links{ display:flex; flex-direction:column; gap:10px; font-size:14px; }
  .contact-links .k{ color:var(--slate); font-size:12px; }
  .foot-note{ margin-top:56px; padding-top:24px; border-top:1px solid var(--line); font-size:12.5px; color:var(--slate); display:flex; justify-content:space-between; flex-wrap:wrap; gap:10px;}

  .reveal{ opacity:0; transform:translateY(18px); transition:opacity .6s ease, transform .6s ease; }
  .reveal.in{ opacity:1; transform:translateY(0); }
  @media (prefers-reduced-motion:reduce){ .reveal{ opacity:1; transform:none; transition:none; } }
</style>
</head>
