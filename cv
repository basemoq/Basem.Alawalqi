<script>
  // language toggle
  const toggle = document.getElementById('langToggle');
  const els = document.querySelectorAll('[data-ar]');
  let lang = 'ar';
  function applyLang(l){
    lang = l;
    document.documentElement.lang = l;
    document.documentElement.dir = l === 'ar' ? 'rtl' : 'ltr';
    document.title = l === 'ar' ? 'باسم — مشرف معرض' : 'Basem — Showroom Supervisor';
    els.forEach(el => { el.textContent = el.getAttribute('data-' + l); });
    toggle.textContent = l === 'ar' ? toggle.getAttribute('data-ar') : toggle.getAttribute('data-en');
  }
  toggle.addEventListener('click', () => applyLang(lang === 'ar' ? 'en' : 'ar'));

  // gauge animation
  const circumference = 2 * Math.PI * 110;
  const gaugeCircle = document.getElementById('gaugeCircle');
  const gaugeNum = document.getElementById('gaugeNum');
  const target = 84.3;
  function runGauge(){
    const offset = circumference - (target / 100) * circumference;
    gaugeCircle.style.strokeDashoffset = offset;
    let start = null;
    const duration = 1400;
    function step(ts){
      if(!start) start = ts;
      const p = Math.min((ts - start) / duration, 1);
      gaugeNum.textContent = (p * target).toFixed(1) + '%';
      if(p < 1) requestAnimationFrame(step);
      else gaugeNum.textContent = target + '%';
    }
    requestAnimationFrame(step);
  }
  window.addEventListener('load', runGauge);

  // reveal on scroll
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('in'); });
  }, { threshold: 0.15 });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));
</script>

